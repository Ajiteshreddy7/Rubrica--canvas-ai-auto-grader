            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            color: #333;
            border-bottom: 2px solid #667eea;
            padding-bottom: 0.5rem;
        }

        .chart-container {
            position: relative;
            margin: 1.5rem 0;
            padding: 1rem;
        }

        .chart-wrapper {
            position: relative;
            height: 400px;
        }

        .chart-wrapper.tall {
            height: 600px;
        }

        .assignment-chart {
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid #eee;
        }

