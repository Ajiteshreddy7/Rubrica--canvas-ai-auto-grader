        }

        .card-title {
            font-size: 0.875rem;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .card-value {
            font-size: 2rem;
            font-weight: bold;
            color: #667eea;
        }

        .section {
            background: white;
            padding: 2rem;
            border-radius: 8px;
